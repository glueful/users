{
    "name": "glueful/users",
    "description": "Users: first-party identity store + account lifecycle for Glueful",
    "type": "glueful-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Glueful Team"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "glueful/framework": "@dev",
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Glueful\\Extensions\\Users\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Glueful\\Extensions\\Users\\Tests\\": "tests/"
        }
    },
    "extra": {
        "glueful": {
            "name": "Users",
            "provider": "Glueful\\Extensions\\Users\\UsersServiceProvider",
            "requires": {
                "glueful": ">=1.30.0",
                "extensions": []
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../../framework",
            "options": {
                "symlink": true
            }
        }
    ]
}
