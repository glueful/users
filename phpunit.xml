<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache">
    <testsuites>
        <testsuite name="Users">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
    <php>
        <!-- Force the array cache so framework boot never resolves Redis (no ext-redis required);
             the booted-app test harness writes array cache config too, but boot can touch cache
             resolution before that app config applies. force=true also overrides a dev's exported
             CACHE_DRIVER=redis. -->
        <env name="CACHE_DRIVER" value="array" force="true"/>
    </php>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
